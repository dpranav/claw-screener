# ── LLM Provider API Keys (at least one required) ──
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...

# ── OpenClaw Settings ──
OPENCLAW_PROVIDER=anthropic
OPENCLAW_MODEL=claude-opus-4-6
OPENCLAW_HOST=0.0.0.0
OPENCLAW_PORT=18789
# OPENCLAW_AUTH_TOKEN=           # optional, secures the gateway
# OPENCLAW_LOG_LEVEL=info        # debug | info | warn | error
# OPENCLAW_TEMPERATURE=0.7
# OPENCLAW_MAX_TOKENS=4096

# ── Skill API Keys ──
# GEMINI_API_KEY=AIza...          # from https://aistudio.google.com/apikey (for nano-banana-pro)

# ── Telegram Channel ──
# TELEGRAM_BOT_TOKEN=                 # main bot token
# PRESALES_TELEGRAM_BOT_TOKEN=        # pre-sales specialist bot token
# SPRINTPLANNER_TELEGRAM_BOT_TOKEN=   # sprint planner bot token
# SPENDCUBE_TELEGRAM_BOT_TOKEN=       # spend cube bot token
# PROCESSMAP_TELEGRAM_BOT_TOKEN=      # process mapping bot token
# TELEGRAM_DM_POLICY=allowlist        # pairing | allowlist | open | disabled
# TELEGRAM_ALLOWED_IDS=5215560516     # comma-separated Telegram user IDs
