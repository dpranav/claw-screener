# ── LLM Provider API Keys (at least one required) ──
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...

# ── OpenClaw Settings ──
OPENCLAW_PROVIDER=anthropic
OPENCLAW_MODEL=anthropic/claude-sonnet-4-5
OPENCLAW_HOST=0.0.0.0
OPENCLAW_PORT=18789
OPENCLAW_ALLOWED_ORIGINS=https://openclaw.proqaai.net
OPENCLAW_ALLOW_HOST_HEADER_FALLBACK=false
# OPENCLAW_AUTH_TOKEN=           # optional, secures the gateway
# OPENCLAW_LOG_LEVEL=info        # debug | info | warn | error
# OPENCLAW_TEMPERATURE=0.7
# OPENCLAW_MAX_TOKENS=4096

# ── Skill API Keys ──
# GEMINI_API_KEY=AIza...          # from https://aistudio.google.com/apikey (for nano-banana-pro)
INSTALL_AGENT_BROWSER_SKILL=true  # install browser skill (uses clawhub --force)
INSTALL_GOOSE_GTM_SKILLS=true     # install all Goose GTM capability skills
GOOSE_SKILLS_REPO_URL=https://github.com/dpranav/goose-skills.git

# ── Telegram Channel ──
# TELEGRAM_BOT_TOKEN=                 # main bot token
# PRESALES_TELEGRAM_BOT_TOKEN=        # pre-sales specialist bot token
# SPRINTPLANNER_TELEGRAM_BOT_TOKEN=   # sprint planner bot token
# SPENDCUBE_TELEGRAM_BOT_TOKEN=       # spend cube bot token
# PROCESSMAP_TELEGRAM_BOT_TOKEN=      # process mapping bot token
# AI_SALES_COACH_TELEGRAM_BOT_TOKEN=  # AI Sales Coach bot token (optional)
# STRAVY_GTM_TELEGRAM_BOT_TOKEN=      # Stravy GTM Agent bot token (optional)
# TELEGRAM_DM_POLICY=allowlist        # pairing | allowlist | open | disabled
# TELEGRAM_ALLOWED_IDS=5215560516     # comma-separated Telegram user IDs
# TELEGRAM_GROUP_IDS=-1003526329009   # comma-separated Telegram group IDs (allowlist mode)
# TELEGRAM_GROUP_REQUIRE_MENTION=true # true/false for requireMention in groups
# TELEGRAM_ACCOUNT_IDS=default,presales,sprintplanner,spendcube,processmap,salescoach,stravygtm
