# ── LLM Provider API Keys (at least one required) ──
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...

# ── OpenClaw Settings ──
OPENCLAW_PROVIDER=anthropic
OPENCLAW_MODEL=anthropic/claude-sonnet-4-5
OPENCLAW_HOST=0.0.0.0
OPENCLAW_PORT=18789
OPENCLAW_ALLOWED_ORIGINS=https://openclaw.proqaai.net
OPENCLAW_ALLOW_HOST_HEADER_FALLBACK=false
# OPENCLAW_AUTH_TOKEN=           # optional, secures the gateway
# OPENCLAW_LOG_LEVEL=info        # debug | info | warn | error
# OPENCLAW_TEMPERATURE=0.7
# OPENCLAW_MAX_TOKENS=4096

# ── Skill API Keys ──
# GEMINI_API_KEY=AIza...          # from https://aistudio.google.com/apikey (for nano-banana-pro)
INSTALL_AGENT_BROWSER_SKILL=true  # install browser skill (uses clawhub --force)
INSTALL_GOOSE_GTM_SKILLS=true     # install all Goose GTM capability skills
GOOSE_SKILLS_REPO_URL=https://github.com/dpranav/goose-skills.git

# ── Telegram Channel ──
# TELEGRAM_BOT_TOKEN=                 # main bot token
# PRESALES_TELEGRAM_BOT_TOKEN=        # pre-sales specialist bot token
# SPRINTPLANNER_TELEGRAM_BOT_TOKEN=   # sprint planner bot token
# SPENDCUBE_TELEGRAM_BOT_TOKEN=       # spend cube bot token
# PROCESSMAP_TELEGRAM_BOT_TOKEN=      # process mapping bot token
# AI_SALES_COACH_TELEGRAM_BOT_TOKEN=  # AI Sales Coach bot token (optional)
# STRAVY_GTM_TELEGRAM_BOT_TOKEN=      # Stravy GTM Agent bot token (optional)
# AI_CFO_TELEGRAM_BOT_TOKEN=          # AI CFO bot token (optional)
# TELEGRAM_DM_POLICY=allowlist        # pairing | allowlist | open | disabled
# TELEGRAM_ALLOWED_IDS=5215560516     # comma-separated Telegram user IDs
# TELEGRAM_GROUP_IDS=-1003526329009   # comma-separated Telegram group IDs (allowlist mode)
# TELEGRAM_GROUP_REQUIRE_MENTION=true # true/false for requireMention in groups
# TELEGRAM_ACCOUNT_IDS=default,presales,sprintplanner,spendcube,processmap,salescoach,stravygtm,aicfo

# ── OpenClaw Hook Endpoint (used by non-Telegram channels) ──
OPENCLAW_HOOK_URL=http://openclaw:18789/hooks/agent
OPENCLAW_INVOKE_MODE=docker_exec
OPENCLAW_CONTAINER_NAME=openclaw-screener

# ── Email Channel (polls inbox and routes emails to agents) ──
EMAIL_CHANNEL_ENABLED=false
EMAIL_PROVIDER=graph
# EMAIL_IMAP_HOST=imap.office365.com
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_USER=agents@stravion.ai
# EMAIL_IMAP_PASSWORD=your-app-password
# EMAIL_IMAP_FOLDER=INBOX
# EMAIL_POLL_SECONDS=30
# Graph app-only mode (recommended for O365):
# EMAIL_GRAPH_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# EMAIL_GRAPH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# EMAIL_GRAPH_CLIENT_SECRET=your-client-secret
# EMAIL_GRAPH_USER_ID=agents@stravion.ai
# EMAIL_GRAPH_MARK_READ=false  # keep false for least privilege (Mail.Read + Mail.Send only)
# EMAIL_PROCESSED_IDS_PATH=/state/email_bridge_processed_ids.txt
# Route by recipient local-part/email: key=agent-id
# EMAIL_AGENT_ROUTING=presales=pre-sales-specialist,sprint=sprint-planner,spendcube=spend-cube-agent,processmap=process-mapping-agent,salescoach=ai-sales-coach,stravygtm=stravy-gtm-agent,cfo=ai-cfo,default=main
# Optional fallback routing by subject tags when aliases are rewritten by O365:
# EMAIL_SUBJECT_AGENT_ROUTING=[presales]=pre-sales-specialist,[sprint]=sprint-planner,[spendcube]=spend-cube-agent,[processmap]=process-mapping-agent,[salescoach]=ai-sales-coach,[stravygtm]=stravy-gtm-agent,[cfo]=ai-cfo
# Optional email auto-reply:
# EMAIL_REPLY_ENABLED=false
# EMAIL_SMTP_HOST=smtp.office365.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=agents@stravion.ai
# EMAIL_SMTP_PASSWORD=your-app-password
# EMAIL_SMTP_FROM=agents@stravion.ai

# ── Voice Channel (live transcript -> AI Sales Coach prompts) ──
VOICE_CHANNEL_ENABLED=false
VOICE_AGENT_ID=ai-sales-coach
VOICE_BRIDGE_PORT=8787
VOICE_API_TOKEN=replace-with-long-random-token
# VOICE_MIN_SECONDS_BETWEEN_PROMPTS=20
# VOICE_MIN_CHARS_BEFORE_PROMPT=160
# VOICE_MAX_CONTEXT_CHARS=5000

# ── Teams Real-Time Bot Adapter (meeting media/text -> Teams Function) ──
TEAMS_RT_BOT_PORT=7090
TEAMS_RT_BOT_LOG_LEVEL=info
TEAMS_RT_BOT_INGEST_TOKEN=replace-with-long-random-token
TEAMS_TRANSCRIPT_FUNCTION_URL=https://stravion-teams-voice-fn.azurewebsites.net/api/teams-transcript?code=replace_function_key
INTEGRATION_TOKEN=replace_integration_token
TEAMS_RT_BOT_REQUEST_TIMEOUT_MS=15000
TEAMS_RT_TIP_MIN_SECONDS_BETWEEN_POSTS=25
TEAMS_RT_TIP_MIN_CHARS=20
TEAMS_RT_TIP_DEDUPE_WINDOW=5
# TEAMS_TIP_WEBHOOK_URL=https://outlook.office.com/webhook/...
TEAMS_RT_MEDIA_FLUSH_SECONDS=4
TEAMS_RT_MEDIA_MAX_CHARS_PER_CHUNK=1200
TEAMS_RT_MEDIA_OVERLAP_WORDS=12
TEAMS_RT_STT_ADAPTER=passthrough
TEAMS_RT_AZURE_SPEECH_KEY=
TEAMS_RT_AZURE_SPEECH_REGION=
TEAMS_RT_STT_LANGUAGE=en-US
TEAMS_RT_STT_SAMPLE_RATE_HZ=16000
TEAMS_RT_STT_BITS_PER_SAMPLE=16
TEAMS_RT_STT_CHANNELS=1
TEAMS_RT_STT_MIN_CONFIDENCE=0.25
