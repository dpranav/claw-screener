# Listener config
PORT=7090
LOG_LEVEL=info

# Optional inbound protection for /api/transcript-chunk
# If set, caller must pass X-Bot-Token header
BOT_INGEST_TOKEN=

# Existing Azure Function from this repo's integration
TEAMS_TRANSCRIPT_FUNCTION_URL=https://stravion-teams-voice-fn.azurewebsites.net/api/teams-transcript?code=replace_function_key
INTEGRATION_TOKEN=replace_integration_token
REQUEST_TIMEOUT_MS=15000

# Tip suppression / throttling
TIP_MIN_SECONDS_BETWEEN_POSTS=25
TIP_MIN_CHARS=20
TIP_DEDUPE_WINDOW=5

# Media chunking contract for /api/media-frame
MEDIA_FLUSH_SECONDS=4
MEDIA_MAX_CHARS_PER_CHUNK=1200
MEDIA_OVERLAP_WORDS=12

# STT adapter mode: passthrough | azure_speech
STT_ADAPTER=passthrough
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
STT_LANGUAGE=en-US
STT_SAMPLE_RATE_HZ=16000
STT_BITS_PER_SAMPLE=16
STT_CHANNELS=1
STT_MIN_CONFIDENCE=0.25

# Optional callback for your bot poster service
# If unset, tips are logged only.
TEAMS_TIP_WEBHOOK_URL=

